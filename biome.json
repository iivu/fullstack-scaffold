{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/.vscode/**/*",
			"**/index.html",
			"**/vite.config.ts",
			"!**/src/routeTree.gen.ts",
			"!**/src/styles.css"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
    "indentWidth": 2
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
      "style": {
        "noNonNullAssertion": { "level": "info" }
      },
      "suspicious": {
        "noExplicitAny": { "level": "info" }
      },
      "correctness": {
        "noUnusedImports": { "level": "off" }
      },
      "a11y": {
        "useSemanticElements": { "level": "info" },
        "noLabelWithoutControl": { "level": "off" },
        "useFocusableInteractive": { "level": "info" }
      }
		}
	},
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
      "lineWidth": 160
		}
	}
}
