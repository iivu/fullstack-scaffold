{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "#/*": ["./src/*"]
    },
    "types": ["node"],
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "jsxImportSource": "hono/jsx",
    /* Bundler mode */
    "moduleResolution": "bundler",
    "noEmit": true,
  },
  "include": ["src", "tsdown.config.ts"],
  "exclude": ["node_modules", "dist"]
}
